alias sizeof='du -h -d 0'

alias ls-dir='ls -d */'

alias g='git'
alias gst='git status'
alias gd='git diff'
alias gds='git diff --staged'
alias gda='git diff HEAD'
alias ginit='git init && git add . && git commit -m "init"'
alias gad='git add .'
alias gac='git add . && git commit -m'
alias gca='git add . && git commit --amend'
alias gcn='git commit --amend --no-edit'
alias gco='git checkout'
alias gc='git commit -m'
alias gps='git push'
alias gpl='git push'
alias gb='git branch'
alias gba='git branch --all'
alias gbd='git branch -d'
alias gbD='git branch -D'
alias gbm='git branch -m'
alias gbr='git branch -r'
alias gprun='git fetch --prune'
alias gres='git restore '

alias sail='./vendor/bin/sail'

alias rl='rlwrap --always-readline'

alias v='nvim'
alias nvi='nvim'
alias e='emacsclient -nw -a ""'
alias em='emacs -nw'
alias ekill='emacsclient -e "(kill-emacs)"'
alias ovim='NVIM_APPNAME=orgnvim nvim'

ec() {
    emacsclient -c -n -a "" "$@"
    osascript -e 'tell application "Emacs" to activate' 2>/dev/null
}

# vim: ft=sh
