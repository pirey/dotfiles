{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#14161b",
    "fg": "#e0e2ea",
    "cyan": "#8cf8f7",
    "blue": "#a6dbff",
    "pink": "#ffcaff",
    "muted": "#3a3d45",
    "border": "#2b2f36",
    "green": "#b3f6c0",
    "yellow": "#fce094",
    "red": "#ffc0b9",
    "comment": "#9b9ea4",
    "selection": "#4f5258"
  },
  "theme": {
    "primary": {
      "dark": "cyan",
      "light": "cyan"
    },
    "secondary": {
      "dark": "blue",
      "light": "blue"
    },
    "accent": {
      "dark": "pink",
      "light": "pink"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "yellow",
      "light": "yellow"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "fg",
      "light": "fg"
    },
    "textMuted": {
      "dark": "comment",
      "light": "comment"
    },
    "background": {
      "dark": "bg",
      "light": "bg"
    },
    "backgroundPanel": {
      "dark": "bg",
      "light": "bg"
    },
    "backgroundElement": {
      "dark": "muted",
      "light": "muted"
    },
    "border": {
      "dark": "border",
      "light": "border"
    },
    "borderActive": {
      "dark": "cyan",
      "light": "cyan"
    },
    "borderSubtle": {
      "dark": "border",
      "light": "border"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "comment",
      "light": "comment"
    },
    "diffHunkHeader": {
      "dark": "muted",
      "light": "muted"
    },
    "diffHighlightAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "#1a3a2a",
      "light": "#1a3a2a"
    },
    "diffRemovedBg": {
      "dark": "#3a1a2a",
      "light": "#3a1a2a"
    },
    "diffContextBg": {
      "dark": "bg",
      "light": "bg"
    },
    "diffLineNumber": {
      "dark": "comment",
      "light": "comment"
    },
    "diffAddedLineNumberBg": {
      "dark": "#1a3a2a",
      "light": "#1a3a2a"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#3a1a2a",
      "light": "#3a1a2a"
    },
    "markdownText": {
      "dark": "fg",
      "light": "fg"
    },
    "markdownHeading": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCode": {
      "dark": "green",
      "light": "green"
    },
    "markdownBlockQuote": {
      "dark": "comment",
      "light": "comment"
    },
    "markdownEmph": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownStrong": {
      "dark": "pink",
      "light": "pink"
    },
    "markdownHorizontalRule": {
      "dark": "muted",
      "light": "muted"
    },
    "markdownListItem": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownListEnumeration": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownImage": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownImageText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxFunction": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxVariable": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxType": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxOperator": {
      "dark": "fg",
      "light": "fg"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "fg"
    }
  }
}
