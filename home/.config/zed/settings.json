// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "none",
  },
  "buffer_font_family": "Ioskeley Mono",
  "theme": "Nightfox",
  "title_bar": {
    "show_sign_in": false,
  },
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
  },
  "languages": {
    "PHP": {
      "format_on_save": "off",
    },
    "Haskell": {
      "formatter": {
        "external": {
          "command": "fourmolu",
          "arguments": ["--stdin-input-file", ""],
        },
      },
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "importModuleSpecifier": "non-relative",
          },
        },
      },
    },
  },
}
