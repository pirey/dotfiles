[user]
    name = Yeri
    email = mail@yeripratama.com

[pager]
    branch = false
    tag = false

[core]
    editor = "$(which nvim) -u NONE"
    excludesfile = ~/.gitignore_global

    ignoredPatterns = *.keystore
    ignoredPatterns = *~
    ignoredPatterns = .DS_Store
    ignoredPatterns = .eslintcache
    ignoredPatterns = node_modules/*
    ignoredPatterns = .vscode
    ignoredPatterns = *.swp
    ignoredPatterns = .venv
    ignoredPatterns = IGNOREME*

[pretty]
    legacy = %Cred%h%Creset - %C(bold blue)<%an>%C(yellow)%d%Creset %Cgreen(%cr)%Creset %s
    colored = %C(red)%h%Creset %C(magenta)%<(10,trunc)%an%C(reset) %C(cyan)%>(12,trunc)%ar%C(reset) │ %s %C(yellow)%d%C(reset)
    plain = %h %<(10,trunc)%an %>(12,trunc)%ar │ %s %d

[alias]
    l = log --pretty=colored --no-merges
    la = log --branches --remotes --tags --oneline --decorate
    gap = log --left-right --oneline --decorate
    compare = log --left-right --oneline --decorate
    co = checkout
    list-files = diff-tree --no-commit-id --name-status -r
    br = for-each-ref --sort=-committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:red)%(objectname:short)%(color:reset) - %(contents:subject) - %(authorname) (%(color:green)%(committerdate:relative)%(color:reset))'
    stash = stash -u
    rlog = reflog --date=local
    logno = log --no-merges
    confg = config --global --list
    committer = shortlog -s -n --all
    fc = "!f() { git log --pretty=colored --decorate --date=short -S\"$1\"; }; f"
    fm = "!f() { git log --pretty=colored --decorate --date=short --grep=\"$1\"; }; f"
